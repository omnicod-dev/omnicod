#!/usr/bin/env node
"use strict"

const { execFileSync } = require("node:child_process")
const path = require("node:path")
const os   = require("node:os")

const PLATFORM = os.platform()   // 'linux' | 'darwin' | 'win32'
const ARCH     = os.arch()       // 'x64'   | 'arm64'

// Map Node.js arch names to our package suffix
const ARCH_MAP = { x64: "x64", arm64: "arm64", aarch64: "arm64" }
const arch = ARCH_MAP[ARCH]

const SUPPORTED = ["linux", "darwin", "win32"]
if (!arch || !SUPPORTED.includes(PLATFORM)) {
  console.error(
    `omnicod: unsupported platform ${PLATFORM}/${ARCH}\n` +
    `Supported: linux/x64, linux/arm64, darwin/x64, darwin/arm64, win32/x64\n` +
    `Build from source: https://github.com/omnicod/omnicod`
  )
  process.exit(1)
}

const pkgName = `@omnicod/cli-${PLATFORM}-${arch}`
const binName = PLATFORM === "win32" ? "omnicod.exe" : "omnicod"

let binPath
try {
  // Resolve the platform-specific binary from optionalDependencies
  const pkgJson = require.resolve(`${pkgName}/package.json`)
  binPath = path.join(path.dirname(pkgJson), "bin", binName)
} catch {
  console.error(
    `omnicod: could not find platform package "${pkgName}"\n` +
    `Try reinstalling: npm install -g omnicod`
  )
  process.exit(1)
}

try {
  execFileSync(binPath, process.argv.slice(2), { stdio: "inherit" })
} catch (err) {
  process.exit(err.status ?? 1)
}
